{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!gui/dist",
			"!gui/src-tauri/target",
			"!gui/src-tauri/gen",
			"!gui/src-tauri/bin",
			"!src/vendor",
			"!**/*.min.js",
			"!pnpm-lock.yaml"
		]
	},
	"formatter": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"complexity": {
				"useOptionalChain": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off"
			},
			"a11y": {
				"noAutofocus": "off"
			}
		}
	},
	"css": {
		"linter": {
			"enabled": false
		}
	},
	"assist": {
		"enabled": false
	}
}
