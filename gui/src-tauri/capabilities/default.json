{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bin/skill-switch-cli",
          "args": ["scan", "--json"],
          "sidecar": true
        },
        {
          "name": "bin/skill-switch-cli",
          "args": ["audit", "--home", "--json"],
          "sidecar": true
        },
        {
          "name": "bin/skill-switch-cli",
          "args": ["doctor", "--json"],
          "sidecar": true
        },
        {
          "name": "bin/skill-switch-cli",
          "args": ["stats", "--days", { "validator": "^[0-9]{1,4}$" }, "--json"],
          "sidecar": true
        },
        {
          "name": "bin/skill-switch-cli",
          "args": ["lock", "--verify", "--json"],
          "sidecar": true
        }
      ]
    }
  ]
}
