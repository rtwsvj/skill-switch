  const local = await isLocalDir(source);
  if (options2.mode === "symlink" && !local) {
    throw new Error("symlink \u6A21\u5F0F\u4EC5\u652F\u6301\u672C\u5730\u76EE\u5F55\u6E90:\u514B\u9686\u7684\u4E34\u65F6\u76EE\u5F55\u4F1A\u88AB\u6E05\u7406,symlink \u4F1A\u60AC\u7A7A");
  }
  const sourceRoot = local ? (0, import_node_path12.resolve)(source) : await cloneRepo(source, options2.ref);
  try {
    let skillDirs = await discoverSkillDirs(sourceRoot);
    if (options2.skill) {
      skillDirs = skillDirs.filter((d) => d.endsWith(`/${options2.skill}`));
    }
    if (skillDirs.length === 0) {
      throw new Error(`\u6765\u6E90\u4E2D\u672A\u53D1\u73B0 skill(\u542B SKILL.md \u7684\u76EE\u5F55): ${source}`);
    }
    const blocked = [];
    if (!options2.force) {
      for (const dir of skillDirs) {
        const report = await auditSkillDir(dir);
        if (shouldBlock(report)) {
          blocked.push({ name: dir.split("/").pop(), score: report.score, report });
        }
      }
      if (blocked.length > 0) {
        return { installed: [], blocked };
      }
    }
    let snapshotPath;
    if ((0, import_node_fs6.existsSync)(skillsDir) && (await (0, import_promises9.readdir)(skillsDir)).length > 0) {
      const snap = await snapshot(skillsDir, {
        store: (0, import_node_path12.join)(options2.home, ".skill-switch", "backups"),
        label: `pre-install-${options2.agent}`
      });
      snapshotPath = snap.path;
    }
    let commit;
    if (!local) {
      const { stdout } = await execFileAsync4("git", ["-C", sourceRoot, "rev-parse", "HEAD"]);
      commit = stdout.trim();
    }
    await (0, import_promises9.mkdir)(skillsDir, { recursive: true });
    const installed = [];
    const lockEntries = [];
    const declarationAdditions = [];
    for (const dir of skillDirs) {
      const name = dir.split("/").pop();
      const target = (0, import_node_path12.join)(skillsDir, name);
      await (0, import_promises9.rm)(target, { recursive: true, force: true });
      if (options2.mode === "symlink") {
        await (0, import_promises9.symlink)(dir, target, "dir");
      } else {
        await (0, import_promises9.cp)(dir, target, { recursive: true });
      }
      installed.push({ name, targetPath: target });
      declarationAdditions.push({
        name,
        agent: options2.agent,
        source: options2.mode === "symlink" ? dir : target,
        mode: options2.mode
      });
      lockEntries.push({
        name,
        agent: options2.agent,
        source: options2.sourceLabel ?? source,
        sourceType: local ? "local" : "git",
        ...options2.ref ? { ref: options2.ref } : {},
        ...commit ? { commit } : {},
        sha256: await computeSkillFolderHash(target),
        mode: options2.mode
      });
    }
    const lockPath = getSkillsLockPath(options2.home);
    await upsertLockEntries(lockPath, lockEntries);
    const declarationPath = getSkillsJsonPath(options2.home);
    await upsertSkillDeclarations(declarationPath, declarationAdditions);
    return { installed, blocked: [], snapshotPath, lockPath, declarationPath };
  } finally {
    if (!local) await cleanupTempDir(sourceRoot).catch(() => {
    });
  }
}

// ../src/cli/commands/install.ts
function registerInstallCommand(program2) {
  program2.command("install").description("\u5B89\u88C5 skill(\u88C5\u524D\u81EA\u52A8 audit + \u5FEB\u7167;S3.4 \u8D77\u5199 skills.lock)").argument("<source>", "git URL(https/file://)\u6216\u672C\u5730\u76EE\u5F55").requiredOption("--agent <agent>", "\u76EE\u6807 agent(\u5982 claude-code\u3001gemini-cli)").option("--home <dir>", "\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home)").option("--mode <mode>", "\u94FA\u8BBE\u65B9\u5F0F:copy | symlink(symlink \u4EC5\u9650\u672C\u5730\u6E90)", "copy").option("--skill <name>", "\u53EA\u88C5\u6765\u6E90\u4E2D\u6307\u5B9A\u76EE\u5F55\u540D\u7684 skill").option("--ref <ref>", "git \u6765\u6E90\u7684\u5206\u652F/tag(\u5199\u5165 skills.lock)").option("--force", "\u8D8A\u8FC7 audit \u62E6\u622A(\u81EA\u62C5\u98CE\u9669)").option("--json", "\u673A\u5668\u53EF\u8BFB JSON \u8F93\u51FA").action(async (source, options2, command) => {
    const home2 = resolveHomeRoot(options2.home ?? command.parent?.opts().home);
    if (options2.mode !== "copy" && options2.mode !== "symlink") {
      throw new Error(`--mode \u53EA\u63A5\u53D7 copy|symlink,\u6536\u5230: ${options2.mode}`);
    }
    const result = await installFromSource(source, {
      home: home2,
      agent: options2.agent,
      mode: options2.mode,
      skill: options2.skill,
      ref: options2.ref,
      force: options2.force
    });
    if (options2.json) {
      console.log(JSON.stringify(result, null, 2));
    } else if (result.blocked.length > 0) {
      console.log("audit \u62E6\u622A,\u672A\u5B89\u88C5\u4EFB\u4F55 skill:");
      for (const b2 of result.blocked) {
        console.log(`  \u2717 ${b2.name}  score=${b2.score}  findings=${b2.report.findings.length}(--force \u53EF\u8D8A\u8FC7)`);
      }
    } else {
      for (const s of result.installed) console.log(`  \u2713 ${s.name} \u2192 ${s.targetPath}`);
      if (result.snapshotPath) console.log(`  \u5FEB\u7167: ${result.snapshotPath}`);
      if (result.lockPath) console.log(`  \u9501: ${result.lockPath}`);
      if (result.declarationPath) console.log(`  \u58F0\u660E: ${result.declarationPath}`);
    }
    if (result.blocked.length > 0) process.exitCode = 1;
  });
}

