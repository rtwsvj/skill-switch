// ../src/vendor/vercel-skills/local-lock.ts
var import_promises3 = require("fs/promises");
var import_path3 = require("path");
var import_crypto = require("crypto");
async function computeSkillFolderHash(skillDir) {
  const files = [];
  await collectFiles(skillDir, skillDir, files);
  files.sort((a, b2) => a.relativePath.localeCompare(b2.relativePath));
  const hash = (0, import_crypto.createHash)("sha256");
  for (const file of files) {
    hash.update(file.relativePath);
    hash.update(file.content);
  }
  return hash.digest("hex");
}
async function collectFiles(baseDir, currentDir, results) {
  const entries = await (0, import_promises3.readdir)(currentDir, { withFileTypes: true });
  await Promise.all(
    entries.map(async (entry) => {
      const fullPath = (0, import_path3.join)(currentDir, entry.name);
      if (entry.isDirectory()) {
        if (entry.name === ".git" || entry.name === "node_modules") return;
        await collectFiles(baseDir, fullPath, results);
      } else if (entry.isFile()) {
        const content = await (0, import_promises3.readFile)(fullPath);
        const relativePath = (0, import_path3.relative)(baseDir, fullPath).split("\\").join("/");
        results.push({ relativePath, content });
      }
    })
  );
}

