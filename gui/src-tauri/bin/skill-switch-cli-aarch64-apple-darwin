async function readDeclaration(path3) {
  try {
    return JSON.parse(await (0, import_promises6.readFile)(path3, "utf8"));
  } catch {
    return { version: 1, skills: [] };
  }
}
async function upsertSkillDeclarations(skillsJsonPath, additions) {
  const current = await readDeclaration(skillsJsonPath);
  const byName = new Map(
    current.skills.map((skill) => [
      skill.name,
      {
        ...skill,
        agents: [...skill.agents],
        ...skill.agentSources ? { agentSources: cloneAgentSources(skill.agentSources) } : {}
      }
    ])
  );
  for (const addition of additions) {
    const existing = byName.get(addition.name);
    if (existing) {
      if (!existing.agents.includes(addition.agent)) existing.agents.push(addition.agent);
      existing.enabled = true;
      const defaultMatches = existing.source === addition.source && existing.mode === addition.mode;
      if (existing.agentSources || !defaultMatches) {
        ensureAgentSources(existing)[addition.agent] = {
          source: addition.source,
          mode: addition.mode
        };
      }
      continue;
    }
    byName.set(addition.name, {
      name: addition.name,
      source: addition.source,
      agents: [addition.agent],
      enabled: true,
      mode: addition.mode
    });
  }
  const next = {
    version: 1,
    skills: [...byName.values()].sort((a, b2) => a.name.localeCompare(b2.name))
  };
  await (0, import_promises6.mkdir)((0, import_node_path7.dirname)(skillsJsonPath), { recursive: true });
  await (0, import_promises6.writeFile)(skillsJsonPath, `${JSON.stringify(next, null, 2)}
`);
  return next;
}
async function removeFromDeclaration(skillsJsonPath, name, agent) {
  const current = await readDeclaration(skillsJsonPath);
  const skills = [];
  for (const skill of current.skills) {
    if (skill.name !== name) {
      skills.push(skill);
      continue;
    }
    const agents2 = skill.agents.filter((a) => a !== agent);
    if (agents2.length === 0) continue;
    const next2 = {
      ...skill,
      agents: agents2,
      ...skill.agentSources ? { agentSources: cloneAgentSources(skill.agentSources) } : {}
    };
    if (next2.agentSources) {
      delete next2.agentSources[agent];
      if (Object.keys(next2.agentSources).length === 0) delete next2.agentSources;
    }
    skills.push(next2);
  }
  const next = {
    version: 1,
    skills: skills.sort((a, b2) => a.name.localeCompare(b2.name))
  };
  await (0, import_promises6.mkdir)((0, import_node_path7.dirname)(skillsJsonPath), { recursive: true });
  await (0, import_promises6.writeFile)(skillsJsonPath, `${JSON.stringify(next, null, 2)}
`);
  return next;
}
function cloneAgentSources(agentSources) {
  return Object.fromEntries(
    Object.entries(agentSources).map(([agent, source]) => [
      agent,
      { ...source }
    ])
  );
}
function ensureAgentSources(skill) {
  const agentSources = skill.agentSources ? cloneAgentSources(skill.agentSources) : {};
  for (const agent of skill.agents) {
    agentSources[agent] ??= { source: skill.source, mode: skill.mode };
  }
  skill.agentSources = agentSources;
  return agentSources;
}
function sourceForAgent(skill, agent) {
  return skill.agentSources?.[agent] ?? { source: skill.source, mode: skill.mode };
}
function sourceAbsFor(home2, source) {
  return (0, import_node_path7.isAbsolute)(source) ? source : (0, import_node_path7.join)(home2, source);
}
function skillsDirFor(home2, agent) {
  const location = getAgentSkillsLocations().find((l) => l.agent === agent);
  if (!location) throw new Error(`\u58F0\u660E\u4E2D\u5305\u542B\u672A\u77E5\u6216\u65E0\u5168\u5C40 skills \u76EE\u5F55\u7684 agent: ${agent}`);
  return resolveGlobalSkillsDir(home2, location);
}
async function inspectTarget(target) {
  try {
    const st = await (0, import_promises6.lstat)(target);
    if (st.isSymbolicLink()) return { state: "symlink", linkTarget: await (0, import_promises6.readlink)(target) };
    return { state: "dir" };
  } catch {
    return { state: "missing" };
  }
}
async function planOne(declared, sourceAbs, mode, agent, target) {
  const base = { agent, name: declared.name, target };
  const actual = await inspectTarget(target);
  if (!declared.enabled) {
    return actual.state === "missing" ? { ...base, kind: "noop", reason: "disabled,\u76EE\u6807\u672C\u5C31\u4E0D\u5B58\u5728" } : { ...base, kind: "remove", reason: "disabled,\u79FB\u9664\u76EE\u6807" };
  }
  if (actual.state === "missing") return { ...base, kind: "create" };
  if (mode === "symlink") {
    if (actual.state === "symlink" && (0, import_node_path7.resolve)(actual.linkTarget) === (0, import_node_path7.resolve)(sourceAbs)) {
      return { ...base, kind: "noop" };
    }
    return { ...base, kind: "replace", reason: "symlink \u6307\u5411\u4E0D\u7B26\u6216\u88AB\u5B9E\u4F53\u76EE\u5F55\u5360\u4F4D" };
  }
  if (actual.state === "dir") {
    const [want, have] = await Promise.all([
      computeSkillFolderHash(sourceAbs),
      computeSkillFolderHash(target)
    ]);
    if (want === have) return { ...base, kind: "noop" };
    return { ...base, kind: "replace", reason: "\u5185\u5BB9\u54C8\u5E0C\u4E0D\u4E00\u81F4" };
  }
  return { ...base, kind: "replace", reason: "copy \u6A21\u5F0F\u4F46\u76EE\u6807\u662F symlink" };
}
async function planSync(home2, declaration) {
  const actions = [];
  for (const skill of declaration.skills) {
    for (const agent of skill.agents) {
      const expected = sourceForAgent(skill, agent);
      const sourceAbs = sourceAbsFor(home2, expected.source);
      if (skill.enabled && !(0, import_node_fs2.existsSync)(sourceAbs)) {
        throw new Error(`\u58F0\u660E\u7684 skill \u6E90\u4E0D\u5B58\u5728: ${skill.name} \u2192 ${sourceAbs}`);
      }
      const target = (0, import_node_path7.join)(skillsDirFor(home2, agent), skill.name);
      if (agent === "codex") {
        const configured = await readCodexSkillEnabled(getCodexConfigPath(home2), target);
        if (!skill.enabled) {
          actions.push(
            configured === false ? { kind: "noop", agent, name: skill.name, target, reason: "config \u5DF2 disabled" } : { kind: "config-disable", agent, name: skill.name, target }
          );
          continue;
        }
        actions.push(await planOne(skill, sourceAbs, expected.mode, agent, target));
        if (configured === false) {
          actions.push({ kind: "config-enable", agent, name: skill.name, target });
        }
        continue;
      }
      actions.push(await planOne(skill, sourceAbs, expected.mode, agent, target));
    }
  }
  return actions;
}
async function applySync(home2, declaration) {
  const actions = await planSync(home2, declaration);
  for (const action of actions) {
    if (action.kind === "noop") continue;
    if (action.kind === "config-disable" || action.kind === "config-enable") {
      await setCodexSkillEnabled(
        getCodexConfigPath(home2),
        action.target,
        action.kind === "config-enable"
      );
      continue;
    }
    await (0, import_promises6.rm)(action.target, { recursive: true, force: true });
    if (action.kind === "remove") continue;
    const declared = declaration.skills.find((s) => s.name === action.name);
    const expected = sourceForAgent(declared, action.agent);
    const sourceAbs = sourceAbsFor(home2, expected.source);
    await (0, import_promises6.mkdir)((0, import_node_path7.join)(action.target, ".."), { recursive: true });
    if (expected.mode === "symlink") {
      await (0, import_promises6.symlink)(sourceAbs, action.target, "dir");
    } else {
      await (0, import_promises6.cp)(sourceAbs, action.target, { recursive: true });
    }
  }
  return { actions };
}

// ../src/core/doctor.ts
function skillsDirFor2(home2, agent) {
  const location = getAgentSkillsLocations().find((l) => l.agent === agent);
  return location ? resolveGlobalSkillsDir(home2, location) : void 0;
}
async function runDoctor(home2) {
  const declaration = await readDeclaration(getSkillsJsonPath(home2));
  const lock = await readSkillsLock(getSkillsLockPath(home2));
  const lockByKey = new Map(lock.skills.map((e) => [`${e.agent}|${e.name}`, e]));
  const findings = [];
  let declaredPairs = 0;
  const declaredKeys = /* @__PURE__ */ new Set();
  for (const skill of declaration.skills) {
    for (const agent of skill.agents) {
      declaredKeys.add(`${agent}|${skill.name}`);
      if (!skill.enabled) continue;
      declaredPairs += 1;
      const skillsDir = skillsDirFor2(home2, agent);
      if (!skillsDir) continue;
      const target = (0, import_node_path8.join)(skillsDir, skill.name);
      if (!(0, import_node_fs3.existsSync)(target)) {
        findings.push({
          kind: "missing",
          agent,
          name: skill.name,
          target,
          detail: "\u58F0\u660E\u4E3A enabled \u4F46\u78C1\u76D8\u4E0A\u4E0D\u5B58\u5728(\u8DD1 sync \u6216 install \u4FEE\u590D)"
        });
        continue;
      }
      const entry = lockByKey.get(`${agent}|${skill.name}`);
      if (!entry) {
        findings.push({
          kind: "stale-lock",
          agent,
          name: skill.name,
          target,
          detail: "\u78C1\u76D8\u5728\u4F4D\u4F46 skills.lock \u65E0\u6761\u76EE(\u9501\u8FC7\u671F\u6216\u7ED5\u8FC7 install \u5B89\u88C5)"
        });
        continue;
      }
      const actual = await computeSkillFolderHash(target);
      if (actual !== entry.sha256) {
        findings.push({
          kind: "content-drift",
          agent,
          name: skill.name,
          target,
          detail: `\u78C1\u76D8\u5185\u5BB9\u54C8\u5E0C ${actual.slice(0, 12)}\u2026 \u2260 \u9501\u5185 ${entry.sha256.slice(0, 12)}\u2026(\u88AB\u672C\u5730\u6539\u52A8\u6216\u4E0A\u6E38\u8986\u76D6)`
        });
      }
    }
  }
  for (const entry of lock.skills) {
    if (!declaredKeys.has(`${entry.agent}|${entry.name}`)) {
      findings.push({
        kind: "extra-locked",
        agent: entry.agent,
        name: entry.name,
        detail: "\u9501\u5185\u6761\u76EE\u4E0D\u5728\u58F0\u660E\u4E2D(\u5B64\u513F\u9501:\u58F0\u660E\u5B83,\u6216\u5378\u8F7D\u5E76\u6E05\u9501)"
      });
    }
  }
  return {
    findings,
    clean: findings.length === 0,
    checked: { declared: declaredPairs, locked: lock.skills.length }
  };
}

// ../src/cli/commands/doctor.ts
function registerDoctorCommand(program2) {
  program2.command("doctor").description("\u58F0\u660E/\u9501/\u78C1\u76D8\u4E09\u65B9\u4E00\u81F4\u6027\u6821\u9A8C(--ci \u6A21\u5F0F\u6F02\u79FB\u5373 exit 1)").option("--home <dir>", "\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home)").option("--ci", "\u6F02\u79FB\u65F6\u4EE5\u975E\u96F6\u9000\u51FA(\u4F9B CI \u4F7F\u7528)").option("--json", "\u673A\u5668\u53EF\u8BFB JSON \u8F93\u51FA").action(async (options2, command) => {
    const home2 = resolveHomeRoot(options2.home ?? command.parent?.opts().home);
    const report = await runDoctor(home2);
    if (options2.json) {
      console.log(JSON.stringify(report, null, 2));
    } else if (report.clean) {
      console.log(`\u2713 \u4E09\u65B9\u4E00\u81F4(\u58F0\u660E ${report.checked.declared} \u9879,\u9501 ${report.checked.locked} \u6761)`);
    } else {
      console.log(`\u2717 \u68C0\u51FA ${report.findings.length} \u5904\u6F02\u79FB:`);
      for (const f of report.findings) {
        console.log(`  [${f.kind}] ${f.agent}/${f.name}${f.target ? `  ${f.target}` : ""}`);
        console.log(`    ${f.detail}`);
