// ../src/cli/commands/lock.ts
var import_node_fs7 = require("node:fs");
var import_node_path14 = require("node:path");
function targetFor(home2, entry) {
  const location = getAgentSkillsLocations().find((l) => l.agent === entry.agent);
  if (!location) return void 0;
  return (0, import_node_path14.join)(resolveGlobalSkillsDir(home2, location), entry.name);
}
async function verifyLock(home2, lockPath, lock) {
  const entries = [];
  for (const entry of lock.skills) {
    const target = targetFor(home2, entry);
    if (!target) {
      entries.push({
        name: entry.name,
        agent: entry.agent,
        expectedSha256: entry.sha256,
        status: "unknown-agent"
      });
      continue;
    }
    if (!(0, import_node_fs7.existsSync)(target)) {
      entries.push({
        name: entry.name,
        agent: entry.agent,
        target,
        expectedSha256: entry.sha256,
        status: "missing"
      });
      continue;
    }
    const actualSha256 = await computeSkillFolderHash(target);
    entries.push({
      name: entry.name,
      agent: entry.agent,
      target,
      expectedSha256: entry.sha256,
      actualSha256,
      status: actualSha256 === entry.sha256 ? "ok" : "mismatch"
    });
  }
  return {
    ok: entries.every((entry) => entry.status === "ok"),
    lockPath,
    entries
  };
}
function printLock(lockPath, lock) {
  if (lock.skills.length === 0) {
    console.log(`skills.lock \u7A7A: ${lockPath}`);
    return;
  }
  console.log(`skills.lock: ${lockPath}`);
  for (const entry of lock.skills) {
    const commit = entry.commit ? ` commit=${entry.commit.slice(0, 12)}` : "";
    console.log(
      `  ${entry.agent}/${entry.name}  ${entry.mode}  ${entry.sourceType}  sha=${entry.sha256.slice(0, 12)}${commit}`
    );
  }
}
function printVerify(report) {
  if (report.ok) {
    console.log(`\u2713 skills.lock \u6821\u9A8C\u901A\u8FC7(${report.entries.length} \u6761): ${report.lockPath}`);
    return;
  }
  console.log(`\u2717 skills.lock \u6821\u9A8C\u5931\u8D25(${report.entries.length} \u6761): ${report.lockPath}`);
  for (const entry of report.entries.filter((e) => e.status !== "ok")) {
    console.log(`  [${entry.status}] ${entry.agent}/${entry.name}${entry.target ? `  ${entry.target}` : ""}`);
    if (entry.actualSha256) {
      console.log(`    \u78C1\u76D8 ${entry.actualSha256.slice(0, 12)}\u2026 \u2260 \u9501\u5185 ${entry.expectedSha256.slice(0, 12)}\u2026`);
    }
  }
}
function registerLockCommand(program2) {
  program2.command("lock").description("\u67E5\u770B skills.lock;--verify \u65F6\u91CD\u7B97\u78C1\u76D8\u54C8\u5E0C\u5E76\u5728\u4E0D\u4E00\u81F4\u65F6 exit 1").option("--home <dir>", "\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home)").option("--verify", "\u91CD\u7B97\u5B89\u88C5\u4EA7\u7269\u54C8\u5E0C,\u4E0E skills.lock \u6BD4\u5BF9").option("--json", "\u673A\u5668\u53EF\u8BFB JSON \u8F93\u51FA").action(async (options2, command) => {
    const home2 = resolveHomeRoot(options2.home ?? command.parent?.opts().home);
    const lockPath = getSkillsLockPath(home2);
    const lock = await readSkillsLock(lockPath);
    if (!options2.verify) {
      if (options2.json) console.log(JSON.stringify({ lockPath, ...lock }, null, 2));
      else printLock(lockPath, lock);
      return;
    }
    const report = await verifyLock(home2, lockPath, lock);
    if (options2.json) console.log(JSON.stringify(report, null, 2));
    else printVerify(report);
    if (!report.ok) process.exitCode = 1;
  });
}

