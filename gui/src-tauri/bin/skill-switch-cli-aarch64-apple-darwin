function getCodexConfigPath(home2) {
  return (0, import_node_path6.join)(home2, ".codex", "config.toml");
}
var SECTION_HEADER = /^\s*\[\[skills\.config\]\]\s*(?:#.*)?$/;
var ANY_HEADER = /^\s*\[/;
var PATH_LINE = /^\s*path\s*=\s*(?:"([^"]*)"|'([^']*)')\s*(?:#.*)?$/;
var ENABLED_LINE = /^\s*enabled\s*=\s*(true|false)\s*(?:#.*)?$/;
function parseSections(lines) {
  const sections = [];
  let current;
  for (let i2 = 0; i2 < lines.length; i2++) {
    const line = lines[i2];
    if (SECTION_HEADER.test(line)) {
      current = { start: i2, end: i2 };
      sections.push(current);
      continue;
    }
    if (ANY_HEADER.test(line)) {
      current = void 0;
      continue;
    }
    if (!current) continue;
    const pathMatch = PATH_LINE.exec(line);
    if (pathMatch) {
      current.path = pathMatch[1] ?? pathMatch[2];
      current.pathLine = i2;
    }
    const enabledMatch = ENABLED_LINE.exec(line);
    if (enabledMatch) {
      current.enabled = enabledMatch[1] === "true";
      current.enabledLine = i2;
    }
    if (line.trim() !== "") current.end = i2;
  }
  return sections;
}
async function readConfigLines(configPath) {
  try {
    return (await (0, import_promises5.readFile)(configPath, "utf8")).split("\n");
  } catch {
    return void 0;
  }
}
async function readCodexSkillEnabled(configPath, skillPath) {
  const lines = await readConfigLines(configPath);
  if (!lines) return void 0;
  const section = parseSections(lines).find((s) => s.path === skillPath);
  if (!section) return void 0;
  return section.enabled ?? true;
}
async function setCodexSkillEnabled(configPath, skillPath, enabled) {
  const original = await readConfigLines(configPath);
  const lines = original ? [...original] : [];
  const section = parseSections(lines).find((s) => s.path === skillPath);
  if (section) {
    const want = `enabled = ${enabled}`;
    if (section.enabledLine !== void 0) {
      if (section.enabled === enabled) return { changed: false };
      lines[section.enabledLine] = want;
    } else {
      lines.splice((section.pathLine ?? section.start) + 1, 0, want);
    }
  } else {
    while (lines.length > 0 && lines[lines.length - 1] === "") lines.pop();
    if (lines.length > 0) lines.push("");
    lines.push("[[skills.config]]", `path = "${skillPath}"`, `enabled = ${enabled}`, "");
  }
  const next = lines.join("\n");
  if (original && next === original.join("\n")) return { changed: false };
  await (0, import_promises5.mkdir)((0, import_node_path6.dirname)(configPath), { recursive: true });
  await (0, import_promises5.writeFile)(configPath, next.endsWith("\n") ? next : `${next}
`);
  return { changed: true };
}

// ../src/core/sync.ts
function getSkillsJsonPath(home2) {
  return (0, import_node_path7.join)(home2, ".skill-switch", "skills.json");
