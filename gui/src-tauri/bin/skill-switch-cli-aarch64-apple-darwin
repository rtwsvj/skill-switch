// ../src/core/paths.ts
var loadTimeHome = (0, import_node_os.homedir)();
function resolveHomeRoot(homeOverride) {
  return homeOverride ?? loadTimeHome;
}
var cachedLocations;
function getAgentSkillsLocations() {
  if (!cachedLocations) {
    const locations = [];
    for (const [agent, config] of Object.entries(agents)) {
      if (!config.globalSkillsDir) continue;
      const rel = (0, import_node_path2.relative)(loadTimeHome, config.globalSkillsDir);
      if (!rel || rel.startsWith("..") || (0, import_node_path2.isAbsolute)(rel)) continue;
      locations.push({ agent, relGlobalSkillsDir: rel });
    }
    cachedLocations = locations;
  }
  return cachedLocations;
}
function resolveGlobalSkillsDir(home2, location) {
  return (0, import_node_path2.join)(home2, location.relGlobalSkillsDir);
}

// ../src/core/scan.ts
var import_promises = require("node:fs/promises");
var import_node_path3 = require("node:path");
var import_gray_matter = __toESM(require_gray_matter(), 1);
function groupAgentsBySkillsDir() {
  const groups = /* @__PURE__ */ new Map();
  for (const location of getAgentSkillsLocations()) {
    const list = groups.get(location.relGlobalSkillsDir) ?? [];
    list.push(location.agent);
    groups.set(location.relGlobalSkillsDir, list);
  }
  return groups;
}
async function isDirectory(path3) {
  try {
    return (await (0, import_promises.stat)(path3)).isDirectory();
  } catch {
    return false;
  }
}
async function readSkill(agents2, relSkillsDir, dirName, skillMdPath) {
  const record = { agents: agents2, relSkillsDir, dirName, path: skillMdPath };
  try {
    const raw = await (0, import_promises.readFile)(skillMdPath, "utf8");
    const { data } = (0, import_gray_matter.default)(raw, {});
    if (typeof data.name === "string") record.name = data.name;
    if (typeof data.description === "string") record.description = data.description;
  } catch (cause) {
    record.error = cause instanceof Error ? cause.message : String(cause);
  }
  return record;
}
async function scanHome(home2) {
  const records = [];
  for (const [relSkillsDir, agents2] of groupAgentsBySkillsDir()) {
    const skillsDir = resolveGlobalSkillsDir(home2, { agent: agents2[0], relGlobalSkillsDir: relSkillsDir });
    if (!await isDirectory(skillsDir)) continue;
    for (const entry of await (0, import_promises.readdir)(skillsDir)) {
      const skillDir = (0, import_node_path3.join)(skillsDir, entry);
      if (!await isDirectory(skillDir)) continue;
      const skillMdPath = (0, import_node_path3.join)(skillDir, "SKILL.md");
      try {
        await (0, import_promises.stat)(skillMdPath);
      } catch {
        continue;
      }
      records.push(await readSkill(agents2, relSkillsDir, entry, skillMdPath));
    }
  }
  records.sort(
    (a, b2) => `${a.relSkillsDir}|${a.dirName}`.localeCompare(`${b2.relSkillsDir}|${b2.dirName}`)
  );
  return records;
}

// ../src/cli/commands/audit.ts
var BLOCKING_SEVERITIES = /* @__PURE__ */ new Set(["critical", "high"]);
var TEXT_EXT = /* @__PURE__ */ new Set([".md", ".txt", ".sh", ".bash", ".zsh", ".py", ".js", ".ts", ".json", ".toml", ".yaml", ".yml", ".cfg", ".conf", ""]);
var MAX_FILE_BYTES = 512 * 1024;
function shouldBlock(report) {
  if (report.score < DANGER_THRESHOLD) return true;
  return report.findings.some((f) => BLOCKING_SEVERITIES.has(f.severity));
}
async function collectTextFiles(root) {
  const targets = [];
  async function walk(dir) {
    for (const entry of await (0, import_promises2.readdir)(dir, { withFileTypes: true })) {
      const full = (0, import_node_path4.join)(dir, entry.name);
      if (entry.isDirectory()) {
        if (entry.name === ".git" || entry.name === "node_modules") continue;
        await walk(full);
      } else if (entry.isFile() && TEXT_EXT.has((0, import_node_path4.extname)(entry.name).toLowerCase())) {
        const info2 = await (0, import_promises2.stat)(full);
        if (info2.size > MAX_FILE_BYTES) continue;
        targets.push({ file: (0, import_node_path4.relative)(root, full), content: await (0, import_promises2.readFile)(full, "utf8") });
      }
    }
  }
  const info = await (0, import_promises2.stat)(root);
  if (info.isFile()) {
    targets.push({ file: (0, import_node_path4.relative)((0, import_node_path4.join)(root, ".."), root), content: await (0, import_promises2.readFile)(root, "utf8") });
  } else {
    await walk(root);
  }
  return targets;
}
async function auditSkillDir(path3) {
  const targets = await collectTextFiles(path3);
  return auditContents(allRules, targets, allFileRules);
}
var SEVERITY_ORDER = ["critical", "high", "medium", "low"];
function formatAuditReport(path3, report) {
  const lines = [`audit: ${path3}`, `score: ${report.score}/100  verdict: ${report.verdict}`];
  if (report.findings.length === 0) {
    lines.push("findings: none");
    return lines.join("\n");
  }
  lines.push(`findings: ${report.findings.length}`, "");
  const sorted2 = [...report.findings].sort(
    (a, b2) => SEVERITY_ORDER.indexOf(a.severity) - SEVERITY_ORDER.indexOf(b2.severity)
  );
  for (const f of sorted2) {
    lines.push(`  [${f.severity.toUpperCase()}] ${f.ruleId}  ${f.file}:${f.line}`);
    lines.push(`    ${f.message}`);
    lines.push(`    > ${f.excerpt.trim()}`);
  }
  return lines.join("\n");
}
async function auditHome(home2) {
  const records = await scanHome(home2);
  const uniqueRecords = /* @__PURE__ */ new Map();
  for (const record of records) {
    uniqueRecords.set((0, import_node_path4.dirname)(record.path), record);
  }
  const skills = [];
  for (const [dir, record] of uniqueRecords) {
    const report = await auditSkillDir(dir);
    skills.push({
      ...report,
      name: record.name ?? record.dirName,
      dirName: record.dirName,
      dir,
      path: dir,
      agents: record.agents,
      relSkillsDir: record.relSkillsDir,
      blocked: shouldBlock(report)
    });
  }
  skills.sort((a, b2) => `${a.relSkillsDir}|${a.dirName}`.localeCompare(`${b2.relSkillsDir}|${b2.dirName}`));
  return { home: home2, total: skills.length, skills };
}
function formatAuditHomeTable(report) {
  if (report.skills.length === 0) return `audit home: ${report.home}
\u672A\u53D1\u73B0\u4EFB\u4F55 skill\u3002`;
  const header = ["NAME", "DIR", "SCORE", "VERDICT", "BLOCK"];
  const rows = report.skills.map((skill) => [
    skill.name,
    skill.dir,
    String(skill.score),
    skill.verdict,
    skill.blocked ? "yes" : "no"
  ]);
  const widths = header.map((h2, col) => Math.max(h2.length, ...rows.map((row) => row[col].length)));
  const renderRow = (row) => row.map((cell, col) => cell.padEnd(widths[col])).join("  ").trimEnd();
  return [`audit home: ${report.home}`, renderRow(header), ...rows.map(renderRow)].join("\n");
}
function registerAuditCommand(program2) {
  program2.command("audit").description("\u5BF9 skill \u76EE\u5F55\u6216 home \u5185\u5168\u90E8\u5DF2\u88C5 skill \u505A\u5B89\u5168\u4F53\u68C0(\u7EAF\u8BFB;\u4EFB\u610F critical/high \u6216\u8BC4\u5206<70 \u2192 exit 1)").argument("[path]", "skill \u76EE\u5F55\u6216 SKILL.md \u8DEF\u5F84;\u7701\u7565\u65F6\u626B\u63CF --home \u4E0B\u5168\u90E8\u5DF2\u88C5 skill").option("--home [dir]", "\u542F\u7528 home \u5168\u91CF\u6A21\u5F0F;\u53EF\u9009\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home)").option("--json", "\u673A\u5668\u53EF\u8BFB JSON \u8F93\u51FA").action(async (path3, options2, command) => {
    if (path3) {
      const report2 = await auditSkillDir(path3);
      if (options2.json) {
        console.log(JSON.stringify({ path: path3, ...report2 }, null, 2));
      } else {
        console.log(formatAuditReport(path3, report2));
      }
      if (shouldBlock(report2)) process.exitCode = 1;
      return;
    }
    const optionHome = typeof options2.home === "string" ? options2.home : void 0;
    const home2 = resolveHomeRoot(optionHome ?? command.parent?.opts().home);
    const report = await auditHome(home2);
    if (options2.json) {
      console.log(JSON.stringify(report, null, 2));
    } else {
      console.log(formatAuditHomeTable(report));
    }
    if (report.skills.some((skill) => skill.blocked)) process.exitCode = 1;
  });
}

