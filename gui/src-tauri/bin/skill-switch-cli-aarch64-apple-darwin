// ../src/core/audit/score.ts
var DANGER_THRESHOLD = 70;
var SAFE_THRESHOLD = 90;
var INSTANT_ZERO_CRITICALS = 5;
var WEIGHTS = {
  critical: 20,
  high: 10,
  medium: 3,
  low: 1
};
function scoreFindings(findings) {
  let criticals = 0;
  let penalty = 0;
  for (const { severity } of findings) {
    if (severity === "critical") criticals += 1;
    penalty += WEIGHTS[severity];
  }
  if (criticals >= INSTANT_ZERO_CRITICALS) return 0;
  return Math.max(0, 100 - penalty);
}
function verdictForScore(score) {
  if (score >= SAFE_THRESHOLD) return "SAFE";
  if (score >= DANGER_THRESHOLD) return "REVIEW";
  return "DANGER";
}

// ../src/core/audit/engine.ts
var EXCERPT_LIMIT = 200;
function statelessPattern(pattern) {
  const flags = pattern.flags.replace(/[gy]/g, "");
  return flags === pattern.flags ? pattern : new RegExp(pattern.source, flags);
}
function runRules(rules, targets) {
  const findings = [];
  const compiled = rules.map((rule) => ({ rule, pattern: statelessPattern(rule.pattern) }));
  for (const target of targets) {
    const lines = target.content.split("\n");
    for (let i2 = 0; i2 < lines.length; i2++) {
      const line = lines[i2];
      for (const { rule, pattern } of compiled) {
        if (!pattern.test(line)) continue;
        findings.push({
          ruleId: rule.id,
          severity: rule.severity,
          file: target.file,
          line: i2 + 1,
          excerpt: line.length > EXCERPT_LIMIT ? `${line.slice(0, EXCERPT_LIMIT)}\u2026` : line,
          message: rule.message
        });
      }
    }
  }
  return findings;
}
function excerpt(text) {
  return text.length > EXCERPT_LIMIT ? `${text.slice(0, EXCERPT_LIMIT)}\u2026` : text;
}
function runFileRules(fileRules, targets) {
  const findings = [];
  for (const target of targets) {
    for (const rule of fileRules) {
      const match = rule.evaluate(target);
      if (!match) continue;
      findings.push({
        ruleId: rule.id,
        severity: rule.severity,
        file: target.file,
        line: match.line,
        excerpt: excerpt(match.excerpt),
        message: rule.message
      });
    }
  }
  return findings;
}
function auditContents(rules, targets, fileRules = []) {
  const findings = [...runRules(rules, targets), ...runFileRules(fileRules, targets)];
  const score = scoreFindings(findings);
  return { findings, score, verdict: verdictForScore(score) };
}

