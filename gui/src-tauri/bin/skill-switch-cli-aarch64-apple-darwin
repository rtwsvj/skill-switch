};
async function buildContextPlan(skillPaths, options2) {
  const { budget, minRelevance = 10, projectDir = process.cwd() } = options2;
  const projectSignals = await analyzeProjectSignals(projectDir);
  const scored = [];
  for (const sp of skillPaths) {
    const skill = await scoreSkillRelevance(sp, projectSignals);
    if (skill) scored.push(skill);
  }
  scored.sort((a, b2) => b2.relevance - a.relevance);
  const loaded = [];
  const skipped = [];
  let usedTokens = 0;
  for (const skill of scored) {
    if (skill.relevance < minRelevance) {
      skipped.push(skill);
      continue;
    }
    if (usedTokens + skill.tokens <= budget) {
      loaded.push(skill);
      usedTokens += skill.tokens;
    } else {
      skipped.push(skill);
    }
  }
  return {
    loaded,
    skipped,
    totalTokens: usedTokens,
    budget,
    budgetRemaining: budget - usedTokens
  };
}
async function analyzeProjectSignals(projectDir) {
  const languages = /* @__PURE__ */ new Set();
  const dependencies = /* @__PURE__ */ new Set();
  const fileKeywords = /* @__PURE__ */ new Set();
  try {
    await scanExtensions(projectDir, languages, fileKeywords, 0, 2);
  } catch {
  }
  const pkgPath = (0, import_path6.join)(projectDir, "package.json");
  if ((0, import_fs3.existsSync)(pkgPath)) {
    try {
      const pkg = JSON.parse(await (0, import_promises11.readFile)(pkgPath, "utf-8"));
      const allDeps = {
        ...pkg.dependencies,
        ...pkg.devDependencies
      };
      for (const dep of Object.keys(allDeps || {})) {
        dependencies.add(dep.replace(/^@/, "").replace(/\//g, "-").toLowerCase());
        const lastPart = dep.split("/").pop();
        if (lastPart) dependencies.add(lastPart.toLowerCase());
      }
      if (pkg.scripts) {
        for (const script of Object.values(pkg.scripts)) {
          const words = script.split(/\s+/).filter((w) => w.length > 3);
          words.forEach((w) => fileKeywords.add(w.toLowerCase()));
        }
      }
    } catch {
    }
  }
  const reqPath = (0, import_path6.join)(projectDir, "requirements.txt");
  if ((0, import_fs3.existsSync)(reqPath)) {
    try {
      const content = await (0, import_promises11.readFile)(reqPath, "utf-8");
      for (const line of content.split("\n")) {
        const pkg = line.trim().split(/[=<>!]/)[0].trim();
        if (pkg && !pkg.startsWith("#")) {
          dependencies.add(pkg.toLowerCase());
        }
      }
    } catch {
    }
  }
  const cargoPath = (0, import_path6.join)(projectDir, "Cargo.toml");
  if ((0, import_fs3.existsSync)(cargoPath)) {
    try {
      const content = await (0, import_promises11.readFile)(cargoPath, "utf-8");
      const depMatches = content.matchAll(/^\s*(\w[\w-]*)\s*=/gm);
      for (const match of depMatches) {
        dependencies.add(match[1].toLowerCase());
      }
    } catch {
    }
  }
  return {
    languages: [...languages],
    dependencies: [...dependencies],
    fileKeywords: [...fileKeywords]
  };
}
async function scanExtensions(dir, languages, fileKeywords, depth, maxDepth) {
  if (depth >= maxDepth) return;
  const entries = await (0, import_promises11.readdir)(dir, { withFileTypes: true });
  for (const entry of entries) {
    if (entry.name.startsWith(".") || entry.name === "node_modules" || entry.name === "dist") continue;
    if (entry.isFile()) {
      const ext = (0, import_path6.extname)(entry.name).toLowerCase();
      const langs = EXT_TO_LANGUAGE[ext];
      if (langs) langs.forEach((l) => languages.add(l));
      const nameWithoutExt = (0, import_path6.basename)(entry.name, ext).toLowerCase();
      if (nameWithoutExt.length > 2) fileKeywords.add(nameWithoutExt);
    } else if (entry.isDirectory()) {
      fileKeywords.add(entry.name.toLowerCase());
      await scanExtensions((0, import_path6.join)(dir, entry.name), languages, fileKeywords, depth + 1, maxDepth);
    }
  }
}
async function scoreSkillRelevance(skillPath, signals) {
  const skillMd = skillPath.endsWith("SKILL.md") ? skillPath : (0, import_path6.join)(skillPath, "SKILL.md");
  if (!(0, import_fs3.existsSync)(skillMd)) return null;
  try {
    const raw = await (0, import_promises11.readFile)(skillMd, "utf-8");
    const { data, content } = (0, import_gray_matter3.default)(raw);
    const name = data.name || (0, import_path6.basename)(skillPath);
    const tokens = Math.ceil(raw.length / 4);
    const skillKeywords = extractSignificantWords(content);
    const skillDescription = (data.description || "").toLowerCase();
    let score = 0;
    const reasons = [];
    const langScore = matchScore(skillKeywords, signals.languages) * 40;
    if (langScore > 0) reasons.push(`lang match: ${Math.round(langScore)}pts`);
    score += langScore;
    const depScore = matchScore(skillKeywords, signals.dependencies) * 30;
    if (depScore > 0) reasons.push(`dep match: ${Math.round(depScore)}pts`);
    score += depScore;
    const fileScore = matchScore(skillKeywords, signals.fileKeywords) * 20;
    if (fileScore > 0) reasons.push(`file match: ${Math.round(fileScore)}pts`);
    score += fileScore;
    const allSignals = [...signals.languages, ...signals.dependencies, ...signals.fileKeywords];
    const descWords = skillDescription.split(/\s+/);
    const descHits = descWords.filter((w) => allSignals.some((s) => s.includes(w) || w.includes(s))).length;
    const descScore = Math.min(10, descHits / Math.max(1, descWords.length) * 30);
    if (descScore > 0) reasons.push(`desc match: ${Math.round(descScore)}pts`);
    score += descScore;
    const relevance = Math.round(Math.min(100, Math.max(0, score)));
    const reason = reasons.length > 0 ? reasons.join(", ") : "no project match";
    return { name, path: skillPath, tokens, relevance, reason, content: raw };
  } catch {
    return null;
  }
}
function matchScore(skillWords, signals) {
  if (skillWords.length === 0 || signals.length === 0) return 0;
  let hits = 0;
  const signalSet = new Set(signals);
  for (const word of skillWords) {
    if (signalSet.has(word)) hits++;
    for (const sig of signals) {
      if (sig.includes(word) || word.includes(sig)) {
        hits += 0.5;
        break;
      }
    }
  }
  return Math.min(1, hits / Math.max(1, signals.length));
}
function extractSignificantWords(text) {
  const stopWords = /* @__PURE__ */ new Set([
    "the",
    "and",
    "for",
    "are",
    "but",
    "not",
    "you",
    "all",
    "can",
    "had",
    "her",
    "was",
    "one",
    "our",
    "out",
    "use",
    "has",
    "word",
    "each",
    "make",
    "like",
    "just",
    "over",
    "such",
    "take",
    "than",
    "them",
    "would",
    "other",
    "into",
    "when",
    "some",
    "time",
    "very",
    "your",
    "with",
    "this",
    "that",
    "from",
    "they",
    "been",
    "have",
    "will",
    "should",
    "using",
    "skill"
  ]);
  return [...new Set(
    text.toLowerCase().replace(/[^a-z0-9\s-]/g, " ").split(/\s+/).filter((w) => w.length >= 3 && !stopWords.has(w))
  )];
}

// ../src/core/lint/spec-validator.ts
var import_gray_matter4 = __toESM(require_gray_matter(), 1);
var MAX_SKILL_NAME_LENGTH = 64;
var MAX_DESCRIPTION_LENGTH = 1024;
var MAX_COMPATIBILITY_LENGTH = 500;
var ALLOWED_FIELDS = /* @__PURE__ */ new Set([
  "name",
  "description",
  "license",
  "allowed-tools",
  "metadata",
  "compatibility"
]);
function isNonEmptyString(v) {
  return typeof v === "string" && v.trim() !== "";
}
var NAME_CHARS = /^[\p{L}\p{N}-]+$/u;
function validateName(rawName, dirName) {
  const errors = [];
  if (!isNonEmptyString(rawName)) {
    errors.push("Field 'name' must be a non-empty string");
    return errors;
  }
  const name = rawName.trim().normalize("NFKC");
  if (name.length > MAX_SKILL_NAME_LENGTH) {
    errors.push(
      `Skill name '${name}' exceeds ${MAX_SKILL_NAME_LENGTH} character limit (${name.length} chars)`
    );
  }
  if (name !== name.toLowerCase()) {
    errors.push(`Skill name '${name}' must be lowercase`);
  }
  if (name.startsWith("-") || name.endsWith("-")) {
    errors.push("Skill name cannot start or end with a hyphen");
  }
  if (name.includes("--")) {
    errors.push("Skill name cannot contain consecutive hyphens");
  }
  if (!NAME_CHARS.test(name)) {
    errors.push(
      `Skill name '${name}' contains invalid characters. Only letters, digits, and hyphens are allowed.`
    );
  }
  if (dirName !== void 0 && dirName.normalize("NFKC") !== name) {
    errors.push(`Directory name '${dirName}' must match skill name '${name}'`);
  }
  return errors;
}
function validateDescription(description) {
  if (!isNonEmptyString(description)) {
    return ["Field 'description' must be a non-empty string"];
  }
  if (description.length > MAX_DESCRIPTION_LENGTH) {
    return [
      `Description exceeds ${MAX_DESCRIPTION_LENGTH} character limit (${description.length} chars)`
    ];
  }
  return [];
}
function validateCompatibility(compatibility) {
  if (typeof compatibility !== "string") {
    return ["Field 'compatibility' must be a string"];
  }
  if (compatibility.length > MAX_COMPATIBILITY_LENGTH) {
    return [
      `Compatibility exceeds ${MAX_COMPATIBILITY_LENGTH} character limit (${compatibility.length} chars)`
    ];
  }
  return [];
}
function validateAllowedFields(metadata) {
  const extra = Object.keys(metadata).filter((k2) => !ALLOWED_FIELDS.has(k2)).sort();
  if (extra.length === 0) return [];
  return [
    `Unexpected fields in frontmatter: ${extra.join(", ")}. Only ${[...ALLOWED_FIELDS].sort().join(", ")} are allowed.`
  ];
}
function validateMetadata(metadata, dirName) {
  const errors = [...validateAllowedFields(metadata)];
  if (!("name" in metadata)) {
    errors.push("Missing required field in frontmatter: name");
  } else {
    errors.push(...validateName(metadata.name, dirName));
  }
  if (!("description" in metadata)) {
    errors.push("Missing required field in frontmatter: description");
  } else {
    errors.push(...validateDescription(metadata.description));
  }
  if ("compatibility" in metadata) {
    errors.push(...validateCompatibility(metadata.compatibility));
  }
  return errors;
}

// ../src/core/lint/portability.ts
var CLAUDE_ONLY_FIELDS = {
  "disable-model-invocation": "Codex \u7B49\u4EF7\u7269:\u5728 agents/openai.yaml \u5199 policy.allow_implicit_invocation: false",
  "user-invocable": void 0,
  "argument-hint": void 0,
  model: void 0,
  effort: void 0,
  context: void 0,
  agent: void 0,
  hooks: void 0
};
var TRIGGER_CUES = /use (?:this |it )?(?:when|for|to)|trigger|invoke|when (?:the )?user|当|用于|在.+时/i;
var DESCRIPTION_FRONT_WINDOW = 120;
function checkPortability(metadata, body, target) {
  const issues = [];
  const name = typeof metadata.name === "string" ? metadata.name : "";
  const description = typeof metadata.description === "string" ? metadata.description : "";
  if (target !== "claude-code") {
    for (const [field, advice] of Object.entries(CLAUDE_ONLY_FIELDS)) {
      if (!(field in metadata)) continue;
      issues.push({
        severity: "warning",
        rule: "portability/claude-only-field",
        field,
        message: `\u5B57\u6BB5 '${field}' \u662F Claude Code \u4E13\u6709,\u5728 ${target} \u5C06\u88AB\u5FFD\u7565\u3002${advice ?? ""}`.trim()
      });
    }
    if ("allowed-tools" in metadata) {
      issues.push({
        severity: "warning",
        rule: "portability/allowed-tools-not-portable",
        field: "allowed-tools",
        message: `'allowed-tools' \u7684\u5DE5\u5177\u540D\u5728\u5404\u5BB6\u4E0D\u901A\u7528(\u5982 Claude \u7684 Bash/Read \u5728 ${target} \u65E0\u5BF9\u5E94),\u8FC1\u79FB\u540E\u9700\u6309\u76EE\u6807\u5BB6\u7684\u5DE5\u5177\u540D\u91CD\u5199`
      });
    }
    if (body.includes("$ARGUMENTS")) {
      issues.push({
        severity: "warning",
        rule: "portability/arguments-substitution",
        message: `\u6B63\u6587\u4F7F\u7528 $ARGUMENTS \u53C2\u6570\u66FF\u6362\u2014\u2014\u4EC5 Claude Code \u652F\u6301,\u5728 ${target} \u4F1A\u539F\u6837\u51FA\u73B0\u5728\u63D0\u793A\u8BCD\u91CC`
      });
    }
  }
  if (target === "copilot" && /[:/]/.test(name)) {
    issues.push({
      severity: "error",
      rule: "portability/copilot-namespace-prefix",
      field: "name",
      message: "VS Code Copilot \u5BF9\u63D2\u4EF6\u5206\u53D1\u7684 skill \u81EA\u52A8\u52A0 namespace \u524D\u7F00;\u624B\u5199\u524D\u7F00(\u542B : \u6216 /)\u4F1A\u9759\u9ED8\u52A0\u8F7D\u5931\u8D25,\u79FB\u9664\u524D\u7F00\u8BA9\u5E73\u53F0\u81EA\u884C\u6DFB\u52A0"
    });
  }
  if (target === "codex" && description) {
    const front = description.slice(0, DESCRIPTION_FRONT_WINDOW);
    if (!TRIGGER_CUES.test(front)) {
      issues.push({
        severity: "info",
        rule: "portability/codex-description-truncation",
        field: "description",
        message: `Codex \u521D\u59CB skills \u5217\u8868\u6709 context budget,description \u53EF\u80FD\u88AB\u622A\u77ED\u2014\u2014\u628A\u89E6\u53D1\u8BCD(use when\u2026/\u7528\u4E8E\u2026)\u524D\u7F6E\u5230\u524D ${DESCRIPTION_FRONT_WINDOW} \u5B57\u7B26\u5185`
      });
    }
  }
  return issues;
}

// ../src/core/lint/lint-home.ts
var METADATA_TOKENS_PER_SKILL = 100;
var KNOWN_PLATFORM_FIELDS = new Set(Object.keys(CLAUDE_ONLY_FIELDS));
function filterSpecErrors(specErrors, metadata) {
  const extra = Object.keys(metadata).filter((k2) => !ALLOWED_FIELDS.has(k2));
  const allKnownPlatform = extra.length > 0 && extra.every((k2) => KNOWN_PLATFORM_FIELDS.has(k2));
  if (!allKnownPlatform) return specErrors;
  return specErrors.filter((e) => !e.startsWith("Unexpected fields in frontmatter"));
}
async function lintSkillDir(dir, target) {
  const name = (0, import_node_path13.basename)(dir);
  try {
    const raw = await (0, import_promises12.readFile)(`${dir}/SKILL.md`, "utf8");
    const { data, content } = (0, import_gray_matter5.default)(raw, {});
    const metadata = data;
    const specErrors = filterSpecErrors(validateMetadata(metadata, name), metadata);
    return { dir, name, specErrors, issues: checkPortability(metadata, content, target) };
  } catch (cause) {
    return {
      dir,
      name,
      specErrors: [cause instanceof Error ? cause.message : String(cause)],
      issues: []
    };
  }
}
async function lintHome(home2, target, budget = 8e3) {
  const records = await scanHome(home2);
  const skills = [];
  for (const record of records) {
    skills.push(await lintSkillDir((0, import_node_path13.dirname)(record.path), target));
  }
  const cleanDirs = records.filter((r2) => !r2.error).map((r2) => (0, import_node_path13.dirname)(r2.path));
  const conflicts2 = await detectConflicts(cleanDirs);
  const perAgentMap = /* @__PURE__ */ new Map();
  for (const record of records) {
    perAgentMap.set(record.relSkillsDir, (perAgentMap.get(record.relSkillsDir) ?? 0) + 1);
  }
  const perAgent = [...perAgentMap.entries()].map(
    ([relSkillsDir, skillCount]) => ({
      relSkillsDir,
      skillCount,
      metadataTokens: skillCount * METADATA_TOKENS_PER_SKILL
    })
  );
  let plan;
  try {
    const p2 = await buildContextPlan(cleanDirs, { budget, minRelevance: 0, projectDir: home2 });
    plan = {
      totalTokens: p2.totalTokens,
      budget: p2.budget,
      loaded: p2.loaded.length,
      skipped: p2.skipped.length
    };
  } catch {
    plan = void 0;
  }
  const hasErrors = skills.some((s) => s.specErrors.length > 0 || s.issues.some((i2) => i2.severity === "error")) || conflicts2.summary.critical > 0;
  return { skills, conflicts: conflicts2, budget: { perAgent, plan }, hasErrors };
}

