async function detectConflicts(skillPaths) {
  const skills = [];
  for (const p2 of skillPaths) {
    const skill = await loadSkillContent(p2);
    if (skill) skills.push(skill);
  }
  const conflicts2 = detectContradictions(skills);
  const overlaps = detectOverlaps(skills);
  const critical = conflicts2.filter((c3) => c3.severity === "critical").length;
  const warnings = conflicts2.filter((c3) => c3.severity === "warning").length;
  const estimatedTokenWaste = overlaps.reduce((sum, o2) => sum + o2.tokenWaste, 0);
  return {
    conflicts: conflicts2,
    overlaps,
    summary: {
      total: conflicts2.length + overlaps.length,
      critical,
      warnings,
      overlapCount: overlaps.length,
      estimatedTokenWaste
    }
  };
}
function detectContradictions(skills) {
  const conflicts2 = [];
  for (let i2 = 0; i2 < skills.length; i2++) {
    for (let j2 = i2 + 1; j2 < skills.length; j2++) {
      const a = skills[i2];
      const b2 = skills[j2];
      for (const da of a.directives) {
        for (const db of b2.directives) {
          const opposition = checkOpposition(da, db);
          if (opposition) {
            conflicts2.push({
              severity: opposition.confidence > 0.7 ? "critical" : "warning",
              skillA: a.name,
              skillB: b2.name,
              category: opposition.category,
              description: opposition.description,
              lineA: da.original,
              lineB: db.original
            });
          }
        }
      }
    }
  }
  return conflicts2;
}
function checkOpposition(a, b2) {
  const isOpposing = OPPOSING_VERBS.some(
    ([v1, v2]) => a.verb === v1 && b2.verb === v2 || a.verb === v2 && b2.verb === v1
  );
  if (!isOpposing) return null;
  const similarity = subjectSimilarity(a.subject, b2.subject);
  if (similarity < 0.4) return null;
  const category = categorizeSubject(a.subject + " " + b2.subject);
  return {
    confidence: similarity,
    category,
    description: `"${a.verb} ${a.subject}" conflicts with "${b2.verb} ${b2.subject}"`
  };
}
function subjectSimilarity(a, b2) {
  const wordsA = extractWords(a);
  const wordsB = extractWords(b2);
  if (wordsA.length === 0 || wordsB.length === 0) return 0;
  const setA = new Set(wordsA);
  const setB = new Set(wordsB);
  let intersection = 0;
  for (const word of setA) {
    if (setB.has(word)) intersection++;
  }
  const union = (/* @__PURE__ */ new Set([...setA, ...setB])).size;
  return union === 0 ? 0 : intersection / union;
}
function detectOverlaps(skills) {
  const overlaps = [];
  const seen = /* @__PURE__ */ new Set();
  for (let i2 = 0; i2 < skills.length; i2++) {
    for (let j2 = i2 + 1; j2 < skills.length; j2++) {
      const a = skills[i2];
      const b2 = skills[j2];
      const key = [a.name, b2.name].sort().join("::");
      if (seen.has(key)) continue;
      const headingOverlap = arrayOverlap(a.topics.headings, b2.topics.headings);
      const keywordOverlap = arrayOverlap(a.topics.keywords, b2.topics.keywords);
      const langOverlap = arrayOverlap(a.topics.codeLanguages, b2.topics.codeLanguages);
      const score = headingOverlap * 0.5 + keywordOverlap * 0.35 + langOverlap * 0.15;
      if (score > 0.35) {
        seen.add(key);
        const tokensA = Math.ceil(a.body.length / 4);
        const tokensB = Math.ceil(b2.body.length / 4);
        const waste = Math.round(Math.min(tokensA, tokensB) * score);
        const commonHeadings = a.topics.headings.filter((h2) => b2.topics.headings.includes(h2));
        const commonKeywords = a.topics.keywords.filter((k2) => b2.topics.keywords.includes(k2));
        const topic = commonHeadings.length > 0 ? commonHeadings.slice(0, 3).join(", ") : commonKeywords.slice(0, 5).join(", ");
        overlaps.push({
          skills: [a.name, b2.name],
          topic: topic || "general instructions",
          tokenWaste: waste
        });
      }
    }
  }
  return overlaps;
}
async function loadSkillContent(skillPath) {
  const skillMd = skillPath.endsWith("SKILL.md") ? skillPath : (0, import_path5.join)(skillPath, "SKILL.md");
  if (!(0, import_fs2.existsSync)(skillMd)) return null;
  try {
    const raw = await (0, import_promises10.readFile)(skillMd, "utf-8");
    const { data, content } = (0, import_gray_matter2.default)(raw);
    const name = data.name || (0, import_path5.basename)(skillPath);
    const directives = extractDirectives(content);
    const topics = extractTopics(content);
    return { name, path: skillPath, body: content, directives, topics };
  } catch {
    return null;
  }
}
function extractDirectives(body) {
  const directives = [];
  const lines = body.split("\n");
  for (const line of lines) {
    const trimmed2 = line.trim();
    if (!trimmed2 || trimmed2.startsWith("#") || trimmed2.startsWith("```")) continue;
    for (const { regex, verb } of DIRECTIVE_PATTERNS) {
      const match = trimmed2.match(regex);
      if (match) {
        const subject = match[1].replace(/[.!,;:]+$/, "").trim().toLowerCase();
        if (subject.length > 2 && subject.length < 200) {
          directives.push({ line: trimmed2, verb, subject, original: trimmed2 });
        }
        break;
      }
    }
  }
  return directives;
}
function extractTopics(body) {
  const lines = body.split("\n");
  const headings = [];
  const allWords = [];
  const codeLanguages = [];
  let inCodeBlock = false;
  for (const line of lines) {
    if (line.trim().startsWith("```")) {
      inCodeBlock = !inCodeBlock;
      if (inCodeBlock) {
        const match = line.match(/```(\w+)/);
        if (match && match[1]) {
          codeLanguages.push(match[1].toLowerCase());
        }
      }
      continue;
    }
    if (inCodeBlock) continue;
    const headingMatch = line.match(/^#{2,4}\s+(.+)/);
    if (headingMatch) {
      headings.push(headingMatch[1].toLowerCase().trim());
    }
    const words = extractWords(line);
    allWords.push(...words);
  }
  const freq = /* @__PURE__ */ new Map();
  for (const word of allWords) {
    freq.set(word, (freq.get(word) || 0) + 1);
  }
  const keywords = [...freq.entries()].filter(([, count]) => count >= 2).sort((a, b2) => b2[1] - a[1]).slice(0, 30).map(([word]) => word);
  return {
    keywords,
    headings: [...new Set(headings)],
    codeLanguages: [...new Set(codeLanguages)]
  };
}
function extractWords(text) {
  return text.toLowerCase().replace(/[^a-z0-9\s-]/g, " ").split(/\s+/).filter((w) => w.length >= 3 && !STOP_WORDS.has(w));
}
function arrayOverlap(a, b2) {
  if (a.length === 0 || b2.length === 0) return 0;
  const setA = new Set(a);
  const setB = new Set(b2);
  let intersection = 0;
  for (const item of setA) {
    if (setB.has(item)) intersection++;
  }
  const union = (/* @__PURE__ */ new Set([...setA, ...setB])).size;
  return union === 0 ? 0 : intersection / union;
}
function categorizeSubject(text) {
  const lower = text.toLowerCase();
  const categories = [
    ["formatting", ["format", "indent", "tab", "space", "semicolon", "quote", "lint", "prettier", "eslint"]],
    ["architecture", ["component", "class", "function", "functional", "module", "pattern", "architecture", "structure"]],
    ["testing", ["test", "spec", "jest", "vitest", "mocha", "assert", "mock", "stub"]],
    ["styling", ["css", "style", "tailwind", "sass", "scss", "styled", "theme", "color"]],
    ["state management", ["state", "redux", "zustand", "context", "store", "signal", "observable"]],
    ["dependencies", ["import", "require", "dependency", "package", "library", "framework"]],
    ["language", ["typescript", "javascript", "python", "rust", "go", "java", "type", "interface"]],
    ["security", ["auth", "token", "password", "secret", "encrypt", "cors", "xss", "csrf"]],
    ["deployment", ["deploy", "build", "ci", "cd", "docker", "kubernetes", "vercel", "aws"]],
    ["api", ["api", "rest", "graphql", "endpoint", "route", "fetch", "request", "response"]]
  ];
  for (const [category, keywords] of categories) {
    if (keywords.some((kw) => lower.includes(kw))) return category;
  }
  return "general";
}

// ../src/vendor/agent-skills-cli/context-budget.ts
var import_promises11 = require("fs/promises");
var import_fs3 = require("fs");
