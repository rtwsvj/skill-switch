    console.log(`  target: ${result.targetPath}`);
    console.log(`  \u9501: ${result.lockPath}`);
    console.log(`  \u58F0\u660E: ${result.declarationPath}`);
    for (const snapshot2 of result.snapshots) console.log(`  \u5FEB\u7167: ${snapshot2.path}`);
  });
}

// ../src/cli/commands/restore.ts
var import_node_path17 = require("node:path");
function viewOf(snapshotInfo) {
  return {
    id: String(snapshotInfo.createdAt.getTime()),
    path: snapshotInfo.path,
    label: snapshotInfo.label,
    createdAt: snapshotInfo.createdAt.toISOString(),
    ...snapshotInfo.sourceDir ? { sourceDir: snapshotInfo.sourceDir } : {}
  };
}
function findSnapshot(snapshots, options2) {
  if (options2.latest) return snapshots[0];
  if (options2.id) return snapshots.find((snap) => String(snap.createdAt.getTime()) === options2.id);
  return void 0;
}
function printSnapshotList(store, snapshots) {
  console.log(`snapshots: ${store}`);
  if (snapshots.length === 0) {
    console.log("  none");
    return;
  }
  for (const snap of snapshots) {
    const source = snap.sourceDir ?? "\u6765\u6E90\u672A\u77E5";
    console.log(`  ${snap.createdAt.getTime()}  ${snap.label}  ${snap.createdAt.toISOString()}  ${source}`);
  }
}
function registerRestoreCommand(program2) {
  program2.command("restore").description("\u5217\u51FA\u6216\u8FD8\u539F skill-switch \u5FEB\u7167(\u8FD8\u539F\u524D\u81EA\u52A8 pre-restore \u5FEB\u7167)").option("--home <dir>", "\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home)").option("--id <epochMs>", "\u6309\u5FEB\u7167 id(epochMs)\u8FD8\u539F").option("--latest", "\u8FD8\u539F\u6700\u65B0\u5FEB\u7167").option("--json", "\u673A\u5668\u53EF\u8BFB JSON \u8F93\u51FA").action(async (options2, command) => {
    if (options2.id && options2.latest) throw new Error("--id \u4E0E --latest \u53EA\u80FD\u4E8C\u9009\u4E00");
    const home2 = resolveHomeRoot(options2.home ?? command.parent?.opts().home);
    const store = (0, import_node_path17.join)(home2, ".skill-switch", "backups");
    const snapshots = await listSnapshots(store);
    if (!options2.id && !options2.latest) {
      if (options2.json) {
        console.log(JSON.stringify({ store, snapshots: snapshots.map(viewOf) }, null, 2));
      } else {
        printSnapshotList(store, snapshots);
      }
      return;
    }
    const selected = findSnapshot(snapshots, options2);
    if (!selected) throw new Error(options2.latest ? "\u6CA1\u6709\u53EF\u8FD8\u539F\u7684\u5FEB\u7167" : `\u627E\u4E0D\u5230\u5FEB\u7167 id: ${options2.id}`);
    if (!selected.sourceDir) throw new Error(`\u5FEB\u7167\u7F3A\u5C11 sourceDir manifest,\u65E0\u6CD5\u81EA\u52A8\u8FD8\u539F: ${selected.path}`);
    const safetySnapshot = await snapshot(selected.sourceDir, { store, label: "pre-restore" });
    await restoreSnapshot(selected.path, selected.sourceDir);
    const result = {
      restored: true,
      target: selected.sourceDir,
      snapshot: viewOf(selected),
      safetySnapshot: viewOf(safetySnapshot)
    };
    if (options2.json) {
      console.log(JSON.stringify(result, null, 2));
    } else {
      console.log(`restored: ${selected.path} \u2192 ${selected.sourceDir}`);
      console.log(`pre-restore snapshot: ${safetySnapshot.path}`);
    }
  });
}

// ../src/cli/commands/scan.ts
function formatScanJson(home2, records) {
  return JSON.stringify({ home: home2, total: records.length, skills: records }, null, 2);
}
var MAX_AGENTS_SHOWN = 3;
function agentsCell(record) {
  const { agents: agents2 } = record;
  if (agents2.length <= MAX_AGENTS_SHOWN) return agents2.join(",");
  return `${agents2.slice(0, MAX_AGENTS_SHOWN).join(",")} +${agents2.length - MAX_AGENTS_SHOWN}`;
}
function formatScanTable(records) {
  if (records.length === 0) return "\u672A\u53D1\u73B0\u4EFB\u4F55 skill\u3002";
  const header = ["DIR", "SKILL", "NAME", "AGENTS", "STATUS"];
  const rows = records.map((record) => [
    record.relSkillsDir,
    record.dirName,
    record.name ?? "-",
    agentsCell(record),
    record.error ? `error: ${record.error.split("\n")[0]}` : "ok"
  ]);
  const widths = header.map(
    (h2, col) => Math.max(h2.length, ...rows.map((row) => row[col].length))
  );
  const renderRow = (row) => row.map((cell, col) => cell.padEnd(widths[col])).join("  ").trimEnd();
  return [renderRow(header), ...rows.map(renderRow), "", `\u5171 ${records.length} \u4E2A skill`].join(
    "\n"
  );
}
function registerScanCommand(program2) {
  program2.command("scan").description("\u76D8\u70B9\u5404 agent \u5DF2\u5B89\u88C5\u7684 skill(\u7EAF\u8BFB,\u574F\u6837\u672C\u4EE5 error \u5B57\u6BB5\u5448\u73B0)").option("--home <dir>", "\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home)").option("--json", "\u673A\u5668\u53EF\u8BFB JSON \u8F93\u51FA").action(async (options2, command) => {
    const homeOverride = options2.home ?? command.parent?.opts().home;
    const home2 = resolveHomeRoot(homeOverride);
    const records = await scanHome(home2);
    console.log(options2.json ? formatScanJson(home2, records) : formatScanTable(records));
  });
}

// ../src/core/transcripts.ts
var import_node_fs9 = require("node:fs");
var import_promises15 = require("node:fs/promises");
var import_node_path18 = require("node:path");
function discoverClaudeTranscriptRoots(home2, env2 = process.env) {
  const candidates = [];
  const configDir = env2.CLAUDE_CONFIG_DIR?.trim();
  if (configDir) {
    candidates.push((0, import_node_path18.join)(configDir, "projects"));
  } else {
    candidates.push((0, import_node_path18.join)(home2, ".config", "claude", "projects"));
    candidates.push((0, import_node_path18.join)(home2, ".claude", "projects"));
  }
  return candidates.filter((dir) => (0, import_node_fs9.existsSync)(dir));
}
async function listTranscriptFiles(roots) {
  const files = [];
  async function walk(dir) {
    let entries;
    try {
      entries = await (0, import_promises15.readdir)(dir, { withFileTypes: true });
    } catch {
      return;
    }
    for (const entry of entries) {
      const full = (0, import_node_path18.join)(dir, entry.name);
      if (entry.isDirectory()) await walk(full);
      else if (entry.isFile() && entry.name.endsWith(".jsonl")) files.push(full);
    }
  }
  for (const root of roots) await walk(root);
  return files.sort();
}
function asRecord(v) {
  return typeof v === "object" && v !== null && !Array.isArray(v) ? v : void 0;
}
function parseSkillInvocations(jsonl, sessionFile) {
  const invocations = [];
  for (const line of jsonl.split("\n")) {
    if (!line.trim()) continue;
    let parsed;
    try {
      parsed = JSON.parse(line);
    } catch {
      continue;
    }
    const record = asRecord(parsed);
    const message = asRecord(record?.message);
    const content = message?.content;
    if (!Array.isArray(content)) continue;
    for (const block of content) {
      const b2 = asRecord(block);
      if (!b2 || b2.type !== "tool_use" || b2.name !== "Skill") continue;
      const input = asRecord(b2.input);
      if (!input || typeof input.skill !== "string" || input.skill === "") continue;
      invocations.push({
        skill: input.skill,
        ...typeof input.args === "string" ? { args: input.args } : {},
        ...typeof record?.timestamp === "string" ? { timestamp: record.timestamp } : {},
        sessionFile
      });
    }
  }
  return invocations;
}
async function parseSkillInvocationsFromFiles(files) {
  const all = [];
  for (const file of files) {
    try {
      all.push(...parseSkillInvocations(await (0, import_promises15.readFile)(file, "utf8"), file));
    } catch {
    }
  }
  return all;
}

// ../src/core/stats.ts
async function buildStats(home2, days, env2 = process.env) {
  const roots = discoverClaudeTranscriptRoots(home2, env2);
  const files = await listTranscriptFiles(roots);
  const all = await parseSkillInvocationsFromFiles(files);
  const since = days !== void 0 ? new Date(Date.now() - days * 864e5) : void 0;
  const invocations = since ? all.filter((i2) => i2.timestamp !== void 0 && new Date(i2.timestamp) >= since) : all;
  const byskill = /* @__PURE__ */ new Map();
  for (const invocation of invocations) {
    const usage2 = bySkillGet(byskill, invocation.skill);
    usage2.count += 1;
    if (invocation.timestamp && (!usage2.lastUsed || invocation.timestamp > usage2.lastUsed)) {
      usage2.lastUsed = invocation.timestamp;
    }
  }
  const usage = [...byskill.values()].sort((a, b2) => b2.count - a.count);
  const triggered = new Set(usage.map((u) => u.skill));
  const records = await scanHome(home2);
  const zombies = records.filter((r2) => !triggered.has(r2.dirName) && !(r2.name !== void 0 && triggered.has(r2.name))).map((r2) => ({ name: r2.name ?? r2.dirName, agents: r2.agents, relSkillsDir: r2.relSkillsDir }));
  return {
    ...since ? { since: since.toISOString() } : {},
    scannedFiles: files.length,
    invocations: invocations.length,
    usage,
    zombies
  };
}
function bySkillGet(map, skill) {
  let usage = map.get(skill);
  if (!usage) {
    usage = { skill, count: 0 };
    map.set(skill, usage);
  }
  return usage;
}

// ../src/cli/commands/stats.ts
function registerStatsCommand(program2) {
  program2.command("stats").description("skill \u89E6\u53D1\u7EDF\u8BA1 + \u50F5\u5C38\u6E05\u5355(\u5DF2\u88C5\u96F6\u89E6\u53D1,\u767D\u5360\u5E38\u9A7B metadata)").option("--days <n>", "\u53EA\u7EDF\u8BA1\u6700\u8FD1 N \u5929(\u65E0\u65F6\u95F4\u6233\u7684\u89E6\u53D1\u5C06\u88AB\u6392\u9664)").option("--home <dir>", "\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home)").option("--json", "\u673A\u5668\u53EF\u8BFB JSON \u8F93\u51FA").action(async (options2, command) => {
    const home2 = resolveHomeRoot(options2.home ?? command.parent?.opts().home);
    const days = options2.days !== void 0 ? Number(options2.days) : void 0;
    if (days !== void 0 && (!Number.isFinite(days) || days <= 0)) {
      throw new Error(`--days \u9700\u8981\u6B63\u6570,\u6536\u5230: ${options2.days}`);
    }
    const report = await buildStats(home2, days);
    if (options2.json) {
      console.log(JSON.stringify(report, null, 2));
      return;
    }
    console.log(
      `\u626B\u63CF ${report.scannedFiles} \u4E2A transcript,${report.invocations} \u6B21 skill \u89E6\u53D1` + (report.since ? `(\u81EA ${report.since.slice(0, 10)})` : "")
    );
    for (const u of report.usage) {
      console.log(`  ${String(u.count).padStart(4)}\xD7  ${u.skill}${u.lastUsed ? `  \u6700\u8FD1 ${u.lastUsed.slice(0, 10)}` : ""}`);
    }
    if (report.zombies.length > 0) {
      console.log(`\u50F5\u5C38 skill(\u5DF2\u88C5\u96F6\u89E6\u53D1,\u5404\u5360 \u2248100 tokens \u5E38\u9A7B):`);
      for (const z2 of report.zombies) console.log(`  \u2717 ${z2.name}  (${z2.relSkillsDir})`);
    } else {
      console.log("\u65E0\u50F5\u5C38 skill\u3002");
    }
  });
}

// ../src/cli/commands/sync.ts
function changedAgents(actions) {
  return [...new Set(actions.filter((a) => a.kind !== "noop").map((a) => a.agent))];
}
function printSyncResult(result) {
  const changed = result.actions.filter((a) => a.kind !== "noop").length;
  const mode = result.dryRun ? "dry-run" : "applied";
  console.log(`sync ${mode}: ${changed}/${result.actions.length} actions need changes`);
  for (const action of result.actions) {
    console.log(`  [${action.kind}] ${action.agent}/${action.name}  ${action.target}`);
    if (action.reason) console.log(`    ${action.reason}`);
  }
  for (const snap of result.snapshots) {
    console.log(`  \u5FEB\u7167: ${snap.path}`);
  }
}
function registerSyncCommand(program2) {
  program2.command("sync").description("\u5E94\u7528 skills.json \u58F0\u660E\u5230\u78C1\u76D8(--dry-run \u53EA\u62A5\u544A\u8BA1\u5212)").option("--home <dir>", "\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home)").option("--dry-run", "\u53EA\u8BA1\u7B97\u5E76\u8F93\u51FA\u52A8\u4F5C,\u4E0D\u5199\u78C1\u76D8\u4E5F\u4E0D\u5FEB\u7167").option("--json", "\u673A\u5668\u53EF\u8BFB JSON \u8F93\u51FA").action(async (options2, command) => {
    const home2 = resolveHomeRoot(options2.home ?? command.parent?.opts().home);
    const declarationPath = getSkillsJsonPath(home2);
    const declaration = await readDeclaration(declarationPath);
    const planned = await planSync(home2, declaration);
    const result = {
      declarationPath,
      dryRun: Boolean(options2.dryRun),
      snapshots: [],
      actions: planned
    };
    if (!options2.dryRun) {
      result.snapshots = await snapshotAgents(home2, changedAgents(planned), "pre-sync");
      result.actions = (await applySync(home2, declaration)).actions;
    }
    if (options2.json) console.log(JSON.stringify(result, null, 2));
    else printSyncResult(result);
  });
}

// ../src/core/toggle.ts
var import_promises16 = require("node:fs/promises");
async function writeDeclaration(path3, decl) {
  await (0, import_promises16.writeFile)(path3, `${JSON.stringify(decl, null, 2)}
`);
}
async function toggleSkill(home2, name, enabled) {
  const declarationPath = getSkillsJsonPath(home2);
  const declaration = await readDeclaration(declarationPath);
  const skill = declaration.skills.find((s) => s.name === name);
  if (!skill) {
    throw new Error(`skill \u4E0D\u5728\u58F0\u660E\u4E2D: ${name}(\u5148\u5728 ${declarationPath} \u58F0\u660E,toggle \u53EA\u7FFB enabled \u4F4D)`);
  }
  skill.enabled = enabled;
  await writeDeclaration(declarationPath, declaration);
  const snapshots = await snapshotAgents(
    home2,
    skill.agents,
    `pre-toggle-${name}-${enabled ? "on" : "off"}`
  );
  const { actions } = await applySync(home2, declaration);
  return { name, enabled, declarationPath, snapshots, actions };
}

// ../src/cli/commands/toggle.ts
function registerToggleCommand(program2) {
  program2.command("toggle").description("\u6309\u58F0\u660E\u5F00\u5173 skill(sync \u524D\u81EA\u52A8\u5FEB\u7167;codex \u8D70 config.toml \u539F\u751F\u5F00\u5173)").argument("<skill>", "\u58F0\u660E(skills.json)\u4E2D\u7684 skill \u540D").option("--on", "\u542F\u7528").option("--off", "\u505C\u7528").option("--home <dir>", "\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home)").option("--json", "\u673A\u5668\u53EF\u8BFB JSON \u8F93\u51FA").action(async (skill, options2, command) => {
    if (Boolean(options2.on) === Boolean(options2.off)) {
      throw new Error("\u5FC5\u987B\u4E14\u53EA\u80FD\u6307\u5B9A --on \u6216 --off \u4E4B\u4E00");
    }
    const home2 = resolveHomeRoot(options2.home ?? command.parent?.opts().home);
    const result = await toggleSkill(home2, skill, Boolean(options2.on));
    if (options2.json) {
      console.log(JSON.stringify(result, null, 2));
      return;
    }
    console.log(`${result.enabled ? "\u2713 \u542F\u7528" : "\u2717 \u505C\u7528"} ${result.name}`);
    for (const a of result.actions) console.log(`  [${a.kind}] ${a.agent}: ${a.target}`);
    for (const s of result.snapshots) console.log(`  \u5FEB\u7167: ${s.path}`);
  });
}

// ../src/cli/program.ts
function buildProgram() {
  const program2 = new Command("skill-switch");
  program2.description("\u8DE8 Agent skill \u6CBB\u7406\u5DE5\u5177(\u6CBB\u7406\u5C42,\u4E0E\u5404\u5BB6 CRUD \u5DE5\u5177\u5171\u5B58\u5206\u5DE5)").option("--home <dir>", "\u8986\u76D6 home \u6839\u76EE\u5F55(\u9ED8\u8BA4\u53D6\u7CFB\u7EDF home;\u6D4B\u8BD5\u4E0E\u6F14\u7EC3\u8BF7\u6307\u5411\u5047\u76EE\u5F55)");
  registerScanCommand(program2);
  registerAuditCommand(program2);
  registerInstallCommand(program2);
  registerToggleCommand(program2);
  registerSyncCommand(program2);
  registerRemoveCommand(program2);
  registerRestoreCommand(program2);
  registerLintCommand(program2);
  registerDoctorCommand(program2);
  registerDriftCommand(program2);
  registerStatsCommand(program2);
  registerLockCommand(program2);
  return program2;
}

// scripts/cli-sidecar-entry.ts
async function main() {
  try {
    await buildProgram().parseAsync(process.argv);
  } catch (err) {
    if (err instanceof CommanderError) {
      process.exit(err.exitCode);
    }
    const message = err instanceof Error ? err.message : String(err);
    console.error(`\u9519\u8BEF: ${message}`);
    process.exit(1);
  }
}
