{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "skill-switch",
  "version": "0.8.0",
  "identifier": "dev.skill-switch.governance",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm bundle:cli && pnpm dev",
    "beforeBuildCommand": "pnpm bundle:cli && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "skill-switch",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "PLACEHOLDER — 用 `tauri signer generate -w ~/.tauri/skill-switch.key` 生成密钥对,把公钥(dW50cnVzdGVk... 开头的 base64 字符串)填在这里;真实发布时必须填真实 pubkey 否则更新会被拒绝。",
      "endpoints": [
        "https://github.com/rtwsvj/skill-switch/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/skill-switch-cli"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
